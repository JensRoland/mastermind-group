{
  "name": "mastermind-group",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "cd server && node --watch index.js",
    "dev:client": "cd client && pnpm exec vite",
    "start": "cd server && node index.js",
    "seed": "cd server && node seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
