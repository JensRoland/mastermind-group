BETTERSTACK_SOURCE_TOKEN=your-source-token-here
BETTERSTACK_INGESTING_HOST=dummy-host-for-local-development.example.com

# Clerk SSO (required for topic voting)
CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_ADMIN_USER_ID=user_your-admin-id-here

# OpenRouter (required for topic moderation)
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: topic submission limits
# TOPIC_MAX_LENGTH=500
# TOPIC_MAX_PER_DAY=3
